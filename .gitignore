.env
.env.local
.env.*.local
node_modules/
.DS_Store

# Browser-extracted session cookies (rotate often, never commit).
cookies/

# Generated chapter bodies for manual paste into rulate's CKEditor.
rulate-bodies/

# Per-book translation .md sources (personal — not committed).
translations/

# Local push manifests for the per-site uploaders. Tracks
# `{chapter_id → hash_of_last_pushed_body}` so re-uploads can detect
# external edits. Personal state, never committed.
.rulate-state.json
.mirnovel-state.json

# Scraped novel-platform data (candidates registry + time-series snapshots).
# Personal research data, regenerable from scratch — never committed.
data/jjwxc/
data/fanqie/
data/qidian/

# Excerpts / heads of full books — copyrighted text we never want in git.
# Generated locally with e.g. `head -1000 hpmor.md > hpmor.md.head` and
# kept around for ad-hoc testing. Real `samples/` (small purpose-built
# demo fixtures) are committed; only full-book excerpts are excluded.
*.md.head

# Python bytecode caches.
__pycache__/
*.pyc

# editor swap/backup files
*.swp
*.swo
*~

# local Claude Code settings (per-machine allowlist)
.claude/
