.env
.env.local
.env.*.local
node_modules/
.DS_Store

# Browser-extracted session cookies (rotate often, never commit).
cookies/

# Generated chapter bodies for manual paste into rulate's CKEditor.
rulate-bodies/

# Per-book translation .md sources (personal — not committed).
translations/

# Local push manifest for the rulate uploader. Tracks
# `{chapter_id → hash_of_last_pushed_body}` so re-uploads can detect
# external edits. Personal state, never committed.
.rulate-state.json

# Python bytecode caches.
__pycache__/
*.pyc

# editor swap/backup files
*.swp
*.swo
*~

# local Claude Code settings (per-machine allowlist)
.claude/
