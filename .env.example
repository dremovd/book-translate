# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Values are read raw — do NOT `source .env`. Comments (#) and blank lines
# are skipped.

# ---------------------------------------------------------------------
# POE (LLM provider) — used by Node-side offline tools in scripts/:
#   - build-abtest.mjs (A/B alignment artifacts)
#   - palladius-extract-demo.mjs
# The browser editor does NOT read these; it stores its own model
# selection in localforage via the setup UI. The Python publish flow
# (scripts/publish-rulate.py) does not read these either.
# ---------------------------------------------------------------------
POE_API_KEY=sk-poe-REPLACE_WITH_YOUR_API_KEY_xxxxxxxxxxxxxxxxxxxxxxxx
# Default model for the Node offline scripts. Falls back to
# `gemini-3.1-pro` if unset.
POE_MODEL=gemini-3.1-pro

# ---------------------------------------------------------------------
# rulate.ru publish flow (scripts/publish-rulate.py).
# ---------------------------------------------------------------------
# Login + password: only used if you wire up an automatic login. The
# current Python uploader bypasses login entirely by reusing browser
# session cookies (see RULATE_COOKIE_FILE below), so these are
# optional.
RULATE_LOGIN=your_rulate_login
RULATE_PASSWORD=your_rulate_password

# Target book id (the number after `/book/` in the rulate URL).
RULATE_BOOK_ID=000000

# Target no-space character count for the long-chapter splitter.
# Source chapters with > 2*target chars (no spaces) are split into
# `floor((n-1)/target)` rulate chapters; titles get `.1`/`.2`/...
# suffixes.
RULATE_TARGET_CHARS_NO_SPACES=5000

# Optional. If set to an integer N, the script enables "Подписка" for
# every source chapter whose 1-based index is >= N. Unset / blank
# means "leave the field at rulate's default".
# RULATE_SUBSCRIPTION_FROM_CHAPTER=10

# Optional. curl_cffi browser fingerprint to impersonate. DDoS-Guard
# remembers fingerprints, so when one starts getting flagged, switch
# to another (chrome / chrome131 / safari17_0 / firefox / edge99).
# Default is `chrome131`.
# RULATE_CURL_IMPERSONATE=chrome131

# Path (relative to the repo root) to a file with the browser-extracted
# Cookie header. The file holds a single `key=value; key=value; ...`
# string, exactly as DevTools shows under "Cookie:" on a logged-in
# rulate request. Refresh by re-copying when the session expires.
# Keeping the cookie in its own file avoids `=` and `$` parsing
# headaches in .env.
RULATE_COOKIE_FILE=cookies/rulate.txt
